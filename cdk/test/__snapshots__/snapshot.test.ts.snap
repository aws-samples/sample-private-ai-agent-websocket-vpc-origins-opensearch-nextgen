    "ProxyImageTriggerIsCompleteFn3E4FD989": {
      "DependsOn": [
        "ProxyImageTriggerIsCompleteFnServiceRoleDefaultPolicyD62A0494",
        "ProxyImageTriggerIsCompleteFnServiceRoleF9CA0283",
